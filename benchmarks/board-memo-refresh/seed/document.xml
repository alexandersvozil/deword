        </w:tblBorders>
      </w:tblPr>
      <w:tblGrid>
        <w:gridCol w:w="5000"/>
        <w:gridCol w:w="3000"/>
      </w:tblGrid>
      <w:tr>
        <w:tc><w:p><w:r><w:rPr><w:b/></w:rPr><w:t>Metric</w:t></w:r></w:p></w:tc>
        <w:tc><w:p><w:r><w:rPr><w:b/></w:rPr><w:t>Value</w:t></w:r></w:p></w:tc>
      </w:tr>
      <w:tr>
        <w:tc><w:p><w:r><w:t>FY2026 Revenue Target</w:t></w:r></w:p></w:tc>
        <w:tc><w:p><w:r><w:t>$12.4M</w:t></w:r></w:p></w:tc>
      </w:tr>
      <w:tr>
        <w:tc><w:p><w:r><w:t>Launch Budget</w:t></w:r></w:p></w:tc>
        <w:tc><w:p><w:r><w:t>$2.8M</w:t></w:r></w:p></w:tc>
      </w:tr>
      <w:tr>
        <w:tc><w:p><w:r><w:t>Gross Margin Target</w:t></w:r></w:p></w:tc>
        <w:tc><w:p><w:r><w:t>31%</w:t></w:r></w:p></w:tc>
      </w:tr>
      <w:tr>
        <w:tc><w:p><w:r><w:t>Initial Store Count</w:t></w:r></w:p></w:tc>
        <w:tc><w:p><w:r><w:t>420</w:t></w:r></w:p></w:tc>
      </w:tr>
    </w:tbl>
    <w:p>
      <w:pPr>
        <w:pStyle w:val="Heading1"/>
      </w:pPr>
      <w:r>
        <w:t>Notes</w:t>
      </w:r>
    </w:p>
    <w:p>
      <w:r>
        <w:t>The archived phrase "draft scenario model" refers to a 2025 worksheet name and should remain unchanged in this memo.</w:t>
      </w:r>
    </w:p>
    <w:p>
      <w:r>
        <w:t xml:space="preserve">The </w:t>
      </w:r>
      <w:r>
        <w:t>forecast</w:t>
      </w:r>
      <w:r>
        <w:footnoteReference w:id="2"/>
      </w:r>
      <w:r>
        <w:t xml:space="preserve"> assumptions were updated after the January operating review.</w:t>
      </w:r>
    </w:p>
    <w:p>
      <w:r>
        <w:t>Pending board approval, the finance team will finalize vendor commitments and release the phase-one media plan within five business days.</w:t>
      </w:r>
    </w:p>
