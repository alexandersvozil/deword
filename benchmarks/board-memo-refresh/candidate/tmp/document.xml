          <w:szCs w:val="22"></w:szCs>
        </w:rPr>
        <w:t>This memo summarizes the current launch recommendation for the Horizon Pantry product line and outlines the financing assumptions for the FY2026 planning cycle.</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="5B750031" w14:textId="77777777" w:rsidR="007A523E" w:rsidRPr="0051716D" w:rsidRDefault="00000000" w:rsidP="008631FA">
