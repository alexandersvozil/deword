      <w:r w:rsidRPr="00010715">
        <w:rPr>
          <w:rFonts w:cstheme="minorHAnsi"></w:rFonts>
          <w:sz w:val="22"></w:sz>
          <w:szCs w:val="22"></w:szCs>
        </w:rPr>
        <w:t>Pending board approval, the finance team will finalize vendor commitments and release the phase-one media plan within five business days.</w:t>
      </w:r>
    </w:p>
