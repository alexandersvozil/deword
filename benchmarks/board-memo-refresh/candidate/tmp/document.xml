      </w:pPr>
      <w:r w:rsidRPr="00393CB6"><w:rPr>
          <w:rFonts w:cstheme="minorHAnsi"></w:rFonts>
          <w:sz w:val="22"></w:sz>
          <w:szCs w:val="22"></w:szCs>
        </w:rPr><w:t>The vendor readiness assessment</w:t></w:r><w:r w:rsidR="000D7BEF" w:rsidRPr="00010715">
        <w:rPr>
          <w:rStyle w:val="FootnoteReference"></w:rStyle>
          <w:rFonts w:cstheme="minorHAnsi"></w:rFonts>
          <w:sz w:val="22"></w:sz>
          <w:szCs w:val="22"></w:szCs>
        </w:rPr>
        <w:footnoteReference w:id="2"></w:footnoteReference>
      </w:r><w:r w:rsidRPr="00393CB6"><w:rPr>
          <w:rFonts w:cstheme="minorHAnsi"></w:rFonts>
          <w:sz w:val="22"></w:sz>
          <w:szCs w:val="22"></w:szCs>
        </w:rPr><w:t xml:space="preserve"> informed the staffing plan for the first wave of distributor onboarding.</w:t></w:r>
    </w:p>
    <w:p w14:paraId="0E2CFFF5" w14:textId="7AD8EA62" w:rsidR="007A523E" w:rsidRPr="00010715" w:rsidRDefault="00000000">
      <w:pPr>
        <w:rPr>
          <w:rFonts w:cstheme="minorHAnsi"></w:rFonts>
          <w:sz w:val="22"></w:sz>
          <w:szCs w:val="22"></w:szCs>
        </w:rPr>
