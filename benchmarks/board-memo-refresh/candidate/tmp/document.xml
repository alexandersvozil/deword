    <w:p w14:paraId="50EFBBC8" w14:textId="5CB6A1BB" w:rsidR="00310A61" w:rsidRPr="00010715" w:rsidRDefault="00310A61" w:rsidP="00310A61">
      <w:pPr>
        <w:rPr>
          <w:sz w:val="22"></w:sz>
          <w:szCs w:val="22"></w:szCs>
        </w:rPr>
      </w:pPr>
      <w:r w:rsidRPr="00010715">
        <w:rPr>
          <w:sz w:val="22"></w:sz>
          <w:szCs w:val="22"></w:szCs>
        </w:rPr>
        <w:t>From a governance standpoint, directors asked that management distinguish clearly between archived planning artifacts and the assumptions currently in force for board review. That distinction is especially important for internal models, retailer communication drafts, and supply planning workbooks that may remain accessible after approval of the launch package.</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="3365D5AB" w14:textId="4059F12B" w:rsidR="008631FA" w:rsidRPr="00010715" w:rsidRDefault="00000000">
      <w:pPr>
        <w:rPr>
          <w:rFonts w:cstheme="minorHAnsi"></w:rFonts>
          <w:sz w:val="22"></w:sz>
          <w:szCs w:val="22"></w:szCs>
        </w:rPr>
      </w:pPr>
      <w:r w:rsidRPr="00010715">
        <w:rPr>
          <w:rFonts w:cstheme="minorHAnsi"></w:rFonts>
          <w:sz w:val="22"></w:sz>
          <w:szCs w:val="22"></w:szCs>
        </w:rPr>
        <w:t>The archived phrase &quot;draft scenario model&quot; refers to a 2025 worksheet name and should remain unchanged in this memo.</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="43121938" w14:textId="72A8C6C6" w:rsidR="00010715" w:rsidRDefault="00000000" w:rsidP="00010715">
      <w:pPr>
