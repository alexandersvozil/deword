          <w:rFonts w:cstheme="minorHAnsi"></w:rFonts>
          <w:sz w:val="22"></w:sz>
          <w:szCs w:val="22"></w:szCs>
        </w:rPr>
        <w:lastRenderedPageBreak></w:lastRenderedPageBreak>
        <w:t>The forecast</w:t>
      </w:r>
      <w:r w:rsidR="000D7BEF" w:rsidRPr="00010715">
        <w:rPr>
          <w:rStyle w:val="FootnoteReference"></w:rStyle>
          <w:rFonts w:cstheme="minorHAnsi"></w:rFonts>
          <w:sz w:val="22"></w:sz>
          <w:szCs w:val="22"></w:szCs>
        </w:rPr>
        <w:footnoteReference w:id="1"></w:footnoteReference>
      </w:r>
      <w:r>
        <w:rPr>
          <w:rFonts w:cstheme="minorHAnsi"></w:rFonts>
          <w:sz w:val="22"></w:sz>
          <w:szCs w:val="22"></w:szCs>
        </w:rPr>
        <w:t xml:space="preserve"> assumptions were updated after the January operating review. In addition, the operations and finance teams are coordinating on vendor commitments, inventory staging, and the timing of media activation to reduce avoidable execution bottlenecks. The working assumption is that supply chain readiness, account-level coordination, and disciplined launch sequencing will remain more important to near-term performance than broad geographic expansion.</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="1B3A0FE0" w14:textId="4B51EE9D" w:rsidR="00393CB6" w:rsidRPr="00010715" w:rsidRDefault="00393CB6" w:rsidP="00010715">
